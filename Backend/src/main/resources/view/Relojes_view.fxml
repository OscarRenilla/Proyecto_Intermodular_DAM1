<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      stylesheets="/styles/styles.css"
      fx:controller="dam.code.controller.RelojController"
      spacing="10"
      alignment="CENTER">

    <Label text="Panel Administrador" styleClass="title"/>

    <HBox spacing="10" alignment="CENTER">
        <Label fx:id="lblUsuario"/>
        <Button text="Cerrar Sesión" onAction="#cerrarSesion" styleClass="button-close"/>
    </HBox>

    <HBox spacing="10" alignment="CENTER">
        <TextField fx:id="txtNombre" promptText="Nombre"/>
        <TextField fx:id="txtModelo" promptText="Modelo"/>
        <TextField fx:id="txtDescripcion" promptText="Descripción"/>
        <TextField fx:id="txtStock" promptText="Stock"/>
        <TextField fx:id="txtPrecio" promptText="Precio"/>
    </HBox>

    <HBox spacing="10" alignment="CENTER">
        <Button text="Añadir" onAction="#addReloj" styleClass="btn-primary"/>
        <Button text="Guardar cambios" onAction="#editarReloj" styleClass="btn-secondary"/>
        <Button text="Eliminar" onAction="#eliminarReloj" styleClass="button-close"/>
    </HBox>

    <TableView fx:id="tablaRelojs" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colId" text="Id"/>
            <TableColumn fx:id="colNombre" text="Nombre"/>
            <TableColumn fx:id="colModelo" text="Modelo"/>
            <TableColumn fx:id="colDescripcion" text="Descripción"/>
            <TableColumn fx:id="colStock" text="Stock"/>
            <TableColumn fx:id="colPrecio" text="Precio"/>
        </columns>
    </TableView>

</VBox>