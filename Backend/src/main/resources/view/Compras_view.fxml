<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      stylesheets="/styles/styles.css"
      fx:controller="dam.code.controller.ComprasController"
      spacing="10"
      alignment="CENTER">

    <Label text="Tienda de Relojes" styleClass="title"/>

    <HBox spacing="10" alignment="CENTER">
        <Label fx:id="lblUsuario"/>
        <Button text="Cerrar Sesión" onAction="#cerrarSesion" styleClass="button-close"/>
    </HBox>

    <Label text="Catálogo — doble clic para comprar" styleClass="subtitle"/>
    <TableView fx:id="tablaRelojs" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colCatId" text="Id"/>
            <TableColumn fx:id="colCatNombre" text="Nombre"/>
            <TableColumn fx:id="colCatModelo" text="Modelo"/>
            <TableColumn fx:id="colCatDescripcion" text="Descripción"/>
            <TableColumn fx:id="colCatStock" text="Stock"/>
            <TableColumn fx:id="colCatPrecio" text="Precio"/>
        </columns>
    </TableView>

    <Label text="Mis compras" styleClass="subtitle"/>
    <TableView fx:id="tablaCompras" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colId" text="Id"/>
            <TableColumn fx:id="colNombre" text="Nombre"/>
            <TableColumn fx:id="colModelo" text="Modelo"/>
            <TableColumn fx:id="colDescripcion" text="Descripción"/>
            <TableColumn fx:id="colStock" text="Stock"/>
            <TableColumn fx:id="colPrecio" text="Precio"/>
        </columns>
    </TableView>

</VBox>